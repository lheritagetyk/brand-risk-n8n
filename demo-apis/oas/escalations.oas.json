{
  "openapi": "3.0.3",
  "info": {
    "title": "Acme National Bank - Escalation Tracker API",
    "description": "Tracks escalations created when social media posts require attention from specific teams (PR, Security, Customer Support). The AI workflow auto-creates escalations for negative and critical posts.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://host.docker.internal:3100",
      "description": "Local development (Docker accessible)"
    }
  ],
  "paths": {
    "/api/escalations": {
      "get": {
        "operationId": "listEscalations",
        "summary": "List escalations",
        "description": "Returns escalations joined with post content and customer info. Filter by status, severity, or escalation target team.",
        "parameters": [
          {
            "name": "status",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "open",
                "in_progress",
                "resolved",
                "closed"
              ]
            }
          },
          {
            "name": "severity",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "low",
                "medium",
                "high",
                "critical"
              ]
            }
          },
          {
            "name": "escalation_target",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "pr_team",
                "security_team",
                "customer_support"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of escalations",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "escalations": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/EscalationWithContext"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createEscalation",
        "summary": "Create an escalation",
        "description": "Creates a new escalation for a social media post and updates the post status to 'escalated' with appropriate priority.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "post_id",
                  "escalation_target"
                ],
                "properties": {
                  "post_id": {
                    "type": "integer",
                    "description": "ID of the social media post"
                  },
                  "customer_id": {
                    "type": "integer",
                    "description": "ID of the linked bank customer, if identified"
                  },
                  "escalation_target": {
                    "type": "string",
                    "enum": [
                      "pr_team",
                      "security_team",
                      "customer_support"
                    ],
                    "description": "Team to handle the escalation"
                  },
                  "severity": {
                    "type": "string",
                    "enum": [
                      "low",
                      "medium",
                      "high",
                      "critical"
                    ],
                    "default": "medium"
                  },
                  "notes": {
                    "type": "string",
                    "description": "Additional context for the team handling this"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Escalation created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Escalation"
                }
              }
            }
          },
          "400": {
            "description": "Missing required fields",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/api/escalations/{id}": {
      "patch": {
        "operationId": "updateEscalation",
        "summary": "Update an escalation",
        "description": "Update the status, assignee, or notes of an escalation. Setting status to 'resolved' automatically timestamps resolution and updates the linked post.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "status": {
                    "type": "string",
                    "enum": [
                      "open",
                      "in_progress",
                      "resolved",
                      "closed"
                    ]
                  },
                  "assigned_to": {
                    "type": "string",
                    "description": "Name or ID of the person handling this"
                  },
                  "notes": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated escalation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Escalation"
                }
              }
            }
          },
          "404": {
            "description": "Escalation not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Escalation": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "post_id": {
            "type": "integer"
          },
          "customer_id": {
            "type": "integer"
          },
          "escalation_target": {
            "type": "string"
          },
          "severity": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high",
              "critical"
            ]
          },
          "status": {
            "type": "string",
            "enum": [
              "open",
              "in_progress",
              "resolved",
              "closed"
            ]
          },
          "assigned_to": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          },
          "resolved_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "EscalationWithContext": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "post_id": {
            "type": "integer"
          },
          "customer_id": {
            "type": "integer"
          },
          "escalation_target": {
            "type": "string"
          },
          "severity": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high",
              "critical"
            ]
          },
          "status": {
            "type": "string",
            "enum": [
              "open",
              "in_progress",
              "resolved",
              "closed"
            ]
          },
          "assigned_to": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          },
          "resolved_at": {
            "type": "string",
            "format": "date-time"
          },
          "post_content": {
            "type": "string"
          },
          "author_handle": {
            "type": "string"
          },
          "platform": {
            "type": "string"
          },
          "customer_name": {
            "type": "string"
          },
          "customer_tier": {
            "type": "string"
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          }
        }
      }
    }
  }
}