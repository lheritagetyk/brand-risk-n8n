{
  "openapi": "3.0.3",
  "info": {
    "title": "Acme National Bank - Known Incidents API",
    "description": "Tracks known active service incidents and issues at the bank. The AI agent uses this to cross-reference social media complaints with known problems, enabling more accurate and context-aware responses.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://host.docker.internal:3100",
      "description": "Local development (Docker accessible)"
    }
  ],
  "paths": {
    "/api/incidents": {
      "get": {
        "operationId": "listIncidents",
        "summary": "List all known incidents",
        "description": "Returns known incidents with optional filtering by status or category.",
        "parameters": [
          {
            "name": "status",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "active",
                "monitoring",
                "resolved"
              ]
            }
          },
          {
            "name": "category",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by incident category (e.g., 'Service Outage', 'App Bug', 'Security Concern')"
          }
        ],
        "responses": {
          "200": {
            "description": "List of incidents",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "incidents": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Incident"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createIncident",
        "summary": "Create a new incident",
        "description": "Records a new known incident that the bank is tracking.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "title",
                  "description",
                  "category"
                ],
                "properties": {
                  "title": {
                    "type": "string",
                    "description": "Short title for the incident"
                  },
                  "description": {
                    "type": "string",
                    "description": "Detailed description of the incident"
                  },
                  "category": {
                    "type": "string",
                    "description": "Category: Service Outage, App Bug, Security Concern, etc."
                  },
                  "severity": {
                    "type": "string",
                    "enum": [
                      "low",
                      "medium",
                      "high",
                      "critical"
                    ],
                    "default": "medium"
                  },
                  "affected_services": {
                    "type": "string",
                    "description": "Comma-separated list of affected services"
                  },
                  "started_at": {
                    "type": "string",
                    "format": "date-time"
                  },
                  "public_statement": {
                    "type": "string",
                    "description": "Approved public-facing statement about this incident"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Incident created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Incident"
                }
              }
            }
          },
          "400": {
            "description": "Missing required fields",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/api/incidents/active": {
      "get": {
        "operationId": "getActiveIncidents",
        "summary": "Get active incidents only",
        "description": "Returns only incidents with 'active' or 'monitoring' status, sorted by severity. This is the primary endpoint the AI agent should check to see if a social media complaint relates to a known issue.",
        "responses": {
          "200": {
            "description": "Active incidents",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "incidents": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Incident"
                      }
                    },
                    "count": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/incidents/{id}": {
      "get": {
        "operationId": "getIncident",
        "summary": "Get incident by ID",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Incident details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Incident"
                }
              }
            }
          },
          "404": {
            "description": "Incident not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      },
      "patch": {
        "operationId": "updateIncident",
        "summary": "Update an incident",
        "description": "Update incident status, severity, or public statement. Setting status to 'resolved' auto-timestamps the resolution.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "status": {
                    "type": "string",
                    "enum": [
                      "active",
                      "monitoring",
                      "resolved"
                    ]
                  },
                  "severity": {
                    "type": "string",
                    "enum": [
                      "low",
                      "medium",
                      "high",
                      "critical"
                    ]
                  },
                  "public_statement": {
                    "type": "string"
                  },
                  "resolved_at": {
                    "type": "string",
                    "format": "date-time"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated incident",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Incident"
                }
              }
            }
          },
          "404": {
            "description": "Incident not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Incident": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "category": {
            "type": "string"
          },
          "severity": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high",
              "critical"
            ]
          },
          "status": {
            "type": "string",
            "enum": [
              "active",
              "monitoring",
              "resolved"
            ]
          },
          "affected_services": {
            "type": "string"
          },
          "started_at": {
            "type": "string",
            "format": "date-time"
          },
          "resolved_at": {
            "type": "string",
            "format": "date-time"
          },
          "public_statement": {
            "type": "string"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          }
        }
      }
    }
  }
}